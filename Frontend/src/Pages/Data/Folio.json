{
  "portfolioType": "folio",
  "templateComponent": "Folio",
  "title": "Folio — Modern Minimal Portfolio",
  "sections": [
    {
      "sectionId": "hero",
      "label": "Introduction",
      "instruction": "The first thing visitors see. Make it clear and confident.",
      "fields": [
        {
          "name": "name",
          "label": "Full Name",
          "type": "text",
          "placeholder": "Alex Morgan",
          "required": true
        },
        {
          "name": "title",
          "label": "What You Do",
          "instruction": "Your role or what you specialize in. No job needed.",
          "type": "text",
          "placeholder": "Full Stack Developer",
          "required": true
        },
        {
          "name": "bio",
          "label": "Short Bio",
          "type": "textarea",
          "placeholder": "I build clean, fast web products that people love using. 4 years of experience working with startups and agencies across 3 continents.",
          "instruction": "2-3 sentences about yourself, your experience, and what makes you different.",
          "required": true
        },
        {
          "name": "avatar",
          "label": "Profile Photo",
          "type": "image",
          "multiple": false,
          "instruction": "A clear headshot with a simple background works best."
        },
        {
          "name": "location",
          "label": "Location",
          "type": "text",
          "placeholder": "Lagos, Nigeria"
        },
        {
          "name": "availableForWork",
          "label": "Available for Work",
          "type": "boolean",
          "default": true,
          "instruction": "Shows an availability badge on your profile."
        },
        {
          "name": "resumeLink",
          "label": "Resume",
          "type": "resume",
          "instruction": "Upload your resume as a PDF (max 5MB)."
        },
        {
          "name": "ctaLabel",
          "label": "CTA Button Text",
          "type": "text",
          "placeholder": "Get in Touch",
          "instruction": "Short action text for the top button, e.g. 'Hire Me' or 'Let's Talk'."
        }
      ]
    },
    {
      "sectionId": "skills",
      "label": "Skills",
      "instruction": "Group your skills into categories.",
      "type": "array",
      "min": 1,
      "max": 6,
      "item": {
        "fields": [
          {
            "name": "title",
            "label": "Category Name",
            "type": "text",
            "placeholder": "Frontend",
            "required": true
          },
          {
            "name": "skills",
            "label": "Skills",
            "type": "tags",
            "placeholder": "React, TypeScript, Tailwind CSS",
            "instruction": "Type each skill and press Enter to add.",
            "required": true
          }
        ]
      }
    },
    {
      "sectionId": "experience",
      "label": "Work Experience",
      "instruction": "Add jobs, internships, or freelance work. Turn off if you have none.",
      "fields": [
        {
          "name": "showExperience",
          "label": "Show This Section",
          "type": "boolean",
          "default": true,
          "instruction": "Turn off to hide this section from your portfolio."
        }
      ],
      "type": "array",
      "min": 0,
      "max": 8,
      "item": {
        "fields": [
          {
            "name": "role",
            "label": "Job Title",
            "type": "text",
            "placeholder": "Frontend Developer",
            "required": true
          },
          {
            "name": "company",
            "label": "Company",
            "type": "text",
            "placeholder": "Stripe",
            "required": true
          },
          {
            "name": "period",
            "label": "Duration",
            "type": "text",
            "placeholder": "Jan 2022 – Present"
          },
          {
            "name": "location",
            "label": "Location",
            "type": "text",
            "placeholder": "Remote"
          },
          {
            "name": "description",
            "label": "Description",
            "type": "textarea",
            "placeholder": "Built and maintained the company's main dashboard. Improved page load times by 45%.",
            "instruction": "Key responsibilities and achievements. Use numbers where possible."
          }
        ]
      }
    },
    {
      "sectionId": "projects",
      "label": "Projects",
      "instruction": "Your best work. This is what employers look at first.",
      "type": "array",
      "min": 1,
      "max": 8,
      "item": {
        "fields": [
          {
            "name": "title",
            "label": "Project Name",
            "type": "text",
            "placeholder": "Budget Tracker App",
            "required": true
          },
          {
            "name": "date",
            "label": "Year",
            "type": "text",
            "placeholder": "2024"
          },
          {
            "name": "description",
            "label": "Description",
            "type": "textarea",
            "placeholder": "A personal finance app that helps users track income and expenses. Built with React and Firebase, used by 300+ people.",
            "instruction": "What it does, who uses it, and any impressive numbers.",
            "required": true
          },
          {
            "name": "image",
            "label": "Screenshot",
            "type": "image",
            "multiple": false,
            "instruction": "The most visually appealing view of your project."
          },
          {
            "name": "tags",
            "label": "Technologies",
            "type": "tags",
            "placeholder": "React, Firebase, CSS",
            "instruction": "Type each technology and press Enter to add."
          },
          {
            "name": "github",
            "label": "GitHub URL",
            "type": "link",
            "placeholder": "https://github.com/you/project"
          },
          {
            "name": "webapp",
            "label": "Live URL",
            "type": "link",
            "placeholder": "https://yourproject.vercel.app"
          },
          {
            "name": "showMembers",
            "label": "Team Project",
            "type": "boolean",
            "default": false,
            "instruction": "Turn on to add team members."
          },
          {
            "name": "member",
            "label": "Team Members",
            "type": "array",
            "min": 0,
            "max": 5,
            "item": {
              "fields": [
                {
                  "name": "name",
                  "label": "Name",
                  "type": "text",
                  "placeholder": "Sara Ali"
                },
                {
                  "name": "github",
                  "label": "GitHub URL",
                  "type": "link",
                  "placeholder": "https://github.com/saraali"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "sectionId": "education",
      "label": "Education",
      "instruction": "Your academic background. Include ongoing studies too.",
      "type": "array",
      "min": 0,
      "max": 4,
      "item": {
        "fields": [
          {
            "name": "degree",
            "label": "Degree",
            "type": "text",
            "placeholder": "B.Sc. Computer Science",
            "required": true
          },
          {
            "name": "institution",
            "label": "Institution",
            "type": "text",
            "placeholder": "University of Lagos",
            "required": true
          },
          {
            "name": "period",
            "label": "Years",
            "type": "text",
            "placeholder": "2019 – 2023"
          },
          {
            "name": "grade",
            "label": "Grade / GPA",
            "type": "text",
            "placeholder": "First Class / 3.8 GPA"
          },
          {
            "name": "description",
            "label": "Highlights",
            "type": "textarea",
            "placeholder": "Focused on machine learning and distributed systems. Graduated top of class."
          }
        ]
      }
    },
    {
      "sectionId": "certifications",
      "label": "Certifications",
      "instruction": "Online courses or professional certificates. Turn off if you have none.",
      "fields": [
        {
          "name": "showCertifications",
          "label": "Show This Section",
          "type": "boolean",
          "default": true,
          "instruction": "Turn off to hide this section from your portfolio."
        }
      ],
      "type": "array",
      "min": 0,
      "max": 8,
      "item": {
        "fields": [
          {
            "name": "name",
            "label": "Certificate Name",
            "type": "text",
            "placeholder": "Google UX Design Certificate",
            "required": true
          },
          {
            "name": "issuer",
            "label": "Issued By",
            "type": "text",
            "placeholder": "Google / Coursera"
          },
          {
            "name": "date",
            "label": "Date Completed",
            "type": "text",
            "placeholder": "August 2023"
          },
          {
            "name": "link",
            "label": "Verification Link",
            "type": "link",
            "placeholder": "https://coursera.org/verify/abc123"
          }
        ]
      }
    },
    {
      "sectionId": "contact",
      "label": "Contact",
      "instruction": "How people can reach you.",
      "fields": [
        {
          "name": "email",
          "label": "Email Address",
          "type": "email",
          "placeholder": "alex@example.com",
          "required": true
        },
        {
          "name": "github",
          "label": "GitHub URL",
          "type": "link",
          "placeholder": "https://github.com/alexmorgan"
        },
        {
          "name": "linkedin",
          "label": "LinkedIn URL",
          "type": "link",
          "placeholder": "https://linkedin.com/in/alexmorgan"
        },
        {
          "name": "twitter",
          "label": "Twitter / X URL",
          "type": "link",
          "placeholder": "https://twitter.com/alexmorgan"
        },
        {
          "name": "facebook",
          "label": "Facebook URL",
          "type": "link",
          "placeholder": "https://facebook.com/alexmorgan"
        },
        {
          "name": "instagram",
          "label": "Instagram URL",
          "type": "link",
          "placeholder": "https://instagram.com/alexmorgan"
        }
      ]
    }
  ]
}
