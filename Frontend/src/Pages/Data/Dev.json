{
  "portfolioType": "developer",
  "templateComponent": "Developer",
  "title": "Developer Portfolio",
  "sections": [
    {
      "sectionId": "hero",
      "label": "Introduction",
      "instruction": "Introduce yourself clearly and confidently.",
      "fields": [
        {
          "name": "openToWork",
          "label": "Open to Work",
          "instruction": "Shows an availability badge on your profile.",
          "type": "boolean",
          "default": true
        },
        {
          "name": "fullName",
          "label": "Full Name",
          "type": "text",
          "required": true,
          "placeholder": "John Doe"
        },
        {
          "name": "role",
          "label": "What You Do",
          "instruction": "Your role or what you specialize in. No job needed.",
          "type": "text",
          "required": true,
          "placeholder": "Full Stack Developer"
        },
        {
          "name": "location",
          "label": "Location",
          "type": "text",
          "placeholder": "San Francisco, CA"
        },
        {
          "name": "focus",
          "label": "Focus Areas",
          "instruction": "Comma-separated list of your specialties.",
          "type": "text",
          "placeholder": "React, Node.js, MongoDB"
        },
        {
          "name": "tagline",
          "label": "Tagline",
          "instruction": "One sentence that sums up what you do.",
          "type": "text",
          "required": true,
          "placeholder": "I build fast, clean and scalable web apps"
        },
        {
          "name": "description",
          "label": "Short Bio",
          "instruction": "2-3 sentences about yourself and your experience.",
          "type": "textarea",
          "required": true,
          "placeholder": "I am a full stack developer with 2 years of experience building web applications for startups and freelance clients..."
        }
      ]
    },
    {
      "sectionId": "projects",
      "label": "Projects",
      "instruction": "Showcase your best work. Add 2-6 projects.",
      "type": "array",
      "min": 2,
      "max": 6,
      "item": {
        "fields": [
          {
            "name": "name",
            "label": "Project Name",
            "type": "text",
            "required": true,
            "placeholder": "Portfolio Maker"
          },
          {
            "name": "description",
            "label": "Description",
            "instruction": "What does it do and what problem does it solve?",
            "type": "textarea",
            "required": true,
            "placeholder": "A web app that lets users create beautiful portfolios by filling a simple form..."
          },
          {
            "name": "stack",
            "label": "Tech Stack",
            "instruction": "Type a technology and press Enter to add.",
            "type": "tags",
            "placeholder": "React"
          },
          {
            "name": "githubLink",
            "label": "GitHub URL",
            "type": "link",
            "placeholder": "https://github.com/john/project"
          },
          {
            "name": "liveLink",
            "label": "Live Demo URL",
            "type": "link",
            "placeholder": "https://project.vercel.app"
          },
          {
            "name": "status",
            "label": "Status",
            "type": "text",
            "placeholder": "Production / Open Source / In Progress"
          },
          {
            "name": "images",
            "label": "Screenshots",
            "instruction": "Upload up to 4 screenshots.",
            "type": "image",
            "multiple": true,
            "max": 4
          }
        ]
      }
    },
    {
      "sectionId": "skills",
      "label": "Skills",
      "instruction": "Group your skills into categories.",
      "type": "array",
      "item": {
        "fields": [
          {
            "name": "categoryName",
            "label": "Category Name",
            "type": "text",
            "required": true,
            "placeholder": "Frontend"
          },
          {
            "name": "items",
            "label": "Skills",
            "instruction": "Type a skill and press Enter to add.",
            "type": "tags",
            "required": true,
            "placeholder": "React"
          }
        ]
      }
    },
    {
      "sectionId": "contact",
      "label": "Contact",
      "instruction": "How visitors can reach you.",
      "fields": [
        {
          "name": "email",
          "label": "Email Address",
          "type": "email",
          "required": true,
          "placeholder": "john@example.com"
        },
        {
          "name": "github",
          "label": "GitHub Profile URL",
          "type": "link",
          "required": true,
          "placeholder": "https://github.com/john"
        },
        {
          "name": "linkedin",
          "label": "LinkedIn Profile URL",
          "type": "link",
          "required": true,
          "placeholder": "https://linkedin.com/in/john"
        }
      ]
    }
  ]
}
