{
  "portfolioType": "zohaib",
  "templateComponent": "Zohaib",
  "title": "NeonStack — Developer Portfolio",
  "sections": [
    {
      "sectionId": "hero",
      "label": "Introduction",
      "instruction": "Make a strong first impression with your name, bio, and photo.",
      "fields": [
        {
          "name": "logoText",
          "label": "Logo Text",
          "type": "text",
          "placeholder": "My Portfolio",
          "instruction": "Shows in the top-left corner of your site."
        },
        {
          "name": "showGithubButton",
          "label": "Show GitHub Button",
          "type": "boolean",
          "default": true,
          "instruction": "Displays a GitHub link button in the navbar."
        },
        {
          "name": "githubButtonText",
          "label": "GitHub Button Text",
          "type": "text",
          "placeholder": "Github Profile"
        },
        {
          "name": "fullName",
          "label": "Full Name",
          "type": "text",
          "required": true,
          "placeholder": "John Doe"
        },
        {
          "name": "description",
          "label": "Short Bio",
          "type": "textarea",
          "required": true,
          "placeholder": "I am a passionate developer with experience in building web applications for startups and clients...",
          "instruction": "2-3 sentences about yourself and what you do."
        },
        {
          "name": "profileImage",
          "label": "Profile Photo",
          "type": "image",
          "multiple": false,
          "instruction": "A clear photo of yourself. Shows as a circular image in the hero."
        },
        {
          "name": "resumeLink",
          "label": "Resume",
          "type": "resume",
          "instruction": "Upload your resume as a PDF (max 5MB)."
        }
      ]
    },
    {
      "sectionId": "skills",
      "label": "Skills",
      "instruction": "Group your skills into categories.",
      "type": "array",
      "min": 1,
      "max": 6,
      "item": {
        "fields": [
          {
            "name": "title",
            "label": "Category Name",
            "type": "text",
            "required": true,
            "placeholder": "Frontend"
          },
          {
            "name": "skills",
            "label": "Skills",
            "type": "tags",
            "placeholder": "React",
            "instruction": "Type a skill and press Enter to add.",
            "required": true
          }
        ]
      }
    },
    {
      "sectionId": "experience",
      "label": "Work Experience",
      "instruction": "Add your work history. Turn off if you have none.",
      "fields": [
        {
          "name": "showExperience",
          "label": "Show This Section",
          "type": "boolean",
          "default": true,
          "instruction": "Turn off to hide this section from your portfolio."
        },
        {
          "name": "sectionTitle",
          "label": "Section Heading",
          "type": "text",
          "placeholder": "Work Experience"
        },
        {
          "name": "sectionDesc",
          "label": "Section Description",
          "type": "textarea",
          "placeholder": "Here is a summary of my professional journey so far..."
        },
        {
          "name": "items",
          "label": "Experience Entries",
          "type": "array",
          "min": 0,
          "max": 10,
          "item": {
            "fields": [
              {
                "name": "role",
                "label": "Job Title",
                "type": "text",
                "required": true,
                "placeholder": "Frontend Developer"
              },
              {
                "name": "company",
                "label": "Company",
                "type": "text",
                "required": true,
                "placeholder": "Google"
              },
              {
                "name": "companyLink",
                "label": "Company Website",
                "type": "link",
                "placeholder": "https://google.com"
              },
              {
                "name": "date",
                "label": "Duration",
                "type": "text",
                "required": true,
                "placeholder": "Jan 2023 - Present"
              },
              {
                "name": "desc",
                "label": "Description",
                "type": "textarea",
                "placeholder": "Built and maintained web applications, worked with a team of 5 developers...",
                "instruction": "Key responsibilities and achievements."
              },
              {
                "name": "skills",
                "label": "Skills Used",
                "type": "tags",
                "placeholder": "React",
                "instruction": "Type a skill and press Enter to add."
              },
              {
                "name": "companyLogo",
                "label": "Company Logo",
                "type": "image",
                "multiple": false
              },
              {
                "name": "showDoc",
                "label": "Attach Certificate",
                "type": "boolean",
                "default": false,
                "instruction": "Turn on to attach an experience letter or certificate."
              },
              {
                "name": "doc",
                "label": "Certificate Image",
                "type": "image",
                "multiple": false
              }
            ]
          }
        }
      ]
    },
    {
      "sectionId": "projects",
      "label": "Projects",
      "instruction": "Showcase your best work. Add 1-8 projects.",
      "type": "array",
      "min": 1,
      "max": 8,
      "item": {
        "fields": [
          {
            "name": "title",
            "label": "Project Name",
            "type": "text",
            "required": true,
            "placeholder": "E-Commerce App"
          },
          {
            "name": "date",
            "label": "Year",
            "type": "text",
            "placeholder": "2024"
          },
          {
            "name": "description",
            "label": "Description",
            "type": "textarea",
            "required": true,
            "placeholder": "A full stack e-commerce platform where users can browse, add to cart and checkout products...",
            "instruction": "What it does and what problem it solves."
          },
          {
            "name": "image",
            "label": "Screenshot",
            "type": "image",
            "multiple": false,
            "instruction": "A screenshot or banner image for the project card."
          },
          {
            "name": "tags",
            "label": "Technologies",
            "type": "tags",
            "placeholder": "React",
            "instruction": "Type a technology and press Enter to add."
          },
          {
            "name": "github",
            "label": "GitHub URL",
            "type": "link",
            "placeholder": "https://github.com/yourname/project"
          },
          {
            "name": "webapp",
            "label": "Live URL",
            "type": "link",
            "placeholder": "https://yourproject.vercel.app"
          },
          {
            "name": "showMembers",
            "label": "Team Project",
            "type": "boolean",
            "default": false,
            "instruction": "Turn on to add team members."
          },
          {
            "name": "member",
            "label": "Team Members",
            "type": "array",
            "min": 0,
            "max": 6,
            "item": {
              "fields": [
                {
                  "name": "name",
                  "label": "Name",
                  "type": "text",
                  "placeholder": "Jane Smith"
                },
                {
                  "name": "img",
                  "label": "Photo",
                  "type": "image",
                  "multiple": false
                },
                {
                  "name": "github",
                  "label": "GitHub URL",
                  "type": "link",
                  "placeholder": "https://github.com/member"
                },
                {
                  "name": "linkedin",
                  "label": "LinkedIn URL",
                  "type": "link",
                  "placeholder": "https://linkedin.com/in/member"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "sectionId": "education",
      "label": "Education",
      "instruction": "Your academic background.",
      "fields": [
        {
          "name": "sectionTitle",
          "label": "Section Heading",
          "type": "text",
          "placeholder": "Education"
        },
        {
          "name": "sectionDesc",
          "label": "Section Description",
          "type": "textarea",
          "placeholder": "Here is a summary of my educational journey..."
        },
        {
          "name": "items",
          "label": "Education Entries",
          "type": "array",
          "min": 1,
          "max": 6,
          "item": {
            "fields": [
              {
                "name": "school",
                "label": "Institution",
                "type": "text",
                "required": true,
                "placeholder": "University of Punjab"
              },
              {
                "name": "degree",
                "label": "Degree",
                "type": "text",
                "required": true,
                "placeholder": "Bachelor of Science in Computer Science"
              },
              {
                "name": "date",
                "label": "Duration",
                "type": "text",
                "required": true,
                "placeholder": "2020 - 2024"
              },
              {
                "name": "showGrade",
                "label": "Show Grade",
                "type": "boolean",
                "default": true,
                "instruction": "Turn off if you prefer not to display your grade."
              },
              {
                "name": "grade",
                "label": "Grade / GPA",
                "type": "text",
                "placeholder": "3.5 GPA"
              },
              {
                "name": "desc",
                "label": "Highlights",
                "type": "textarea",
                "placeholder": "Studied core subjects like data structures, algorithms, databases and software engineering..."
              },
              {
                "name": "img",
                "label": "Institute Logo",
                "type": "image",
                "multiple": false
              }
            ]
          }
        }
      ]
    },
    {
      "sectionId": "certifications",
      "label": "Certifications",
      "instruction": "Professional certificates. Turn off if you have none.",
      "fields": [
        {
          "name": "showCertifications",
          "label": "Show This Section",
          "type": "boolean",
          "default": false,
          "instruction": "Turn off to hide this section from your portfolio."
        },
        {
          "name": "items",
          "label": "Certifications",
          "type": "array",
          "min": 0,
          "max": 10,
          "item": {
            "fields": [
              {
                "name": "title",
                "label": "Certificate Name",
                "type": "text",
                "required": true,
                "placeholder": "AWS Certified Developer"
              },
              {
                "name": "issuer",
                "label": "Issued By",
                "type": "text",
                "placeholder": "Amazon Web Services"
              },
              {
                "name": "date",
                "label": "Date",
                "type": "text",
                "placeholder": "March 2024"
              },
              {
                "name": "credentialLink",
                "label": "Verification Link",
                "type": "link",
                "placeholder": "https://credentials.example.com/cert/123"
              },
              {
                "name": "image",
                "label": "Certificate Image",
                "type": "image",
                "multiple": false
              }
            ]
          }
        }
      ]
    },
    {
      "sectionId": "contact",
      "label": "Contact",
      "instruction": "How people can reach you.",
      "fields": [
        {
          "name": "email",
          "label": "Email Address",
          "type": "email",
          "required": true,
          "placeholder": "yourname@example.com"
        },
        {
          "name": "github",
          "label": "GitHub URL",
          "type": "link",
          "required": true,
          "placeholder": "https://github.com/yourname"
        },
        {
          "name": "linkedin",
          "label": "LinkedIn URL",
          "type": "link",
          "placeholder": "https://linkedin.com/in/yourname"
        },
        {
          "name": "facebook",
          "label": "Facebook URL",
          "type": "link",
          "placeholder": "https://facebook.com/yourname"
        },
        {
          "name": "twitter",
          "label": "Twitter / X URL",
          "type": "link",
          "placeholder": "https://twitter.com/yourname"
        },
        {
          "name": "instagram",
          "label": "Instagram URL",
          "type": "link",
          "placeholder": "https://instagram.com/yourname"
        }
      ]
    }
  ]
}
