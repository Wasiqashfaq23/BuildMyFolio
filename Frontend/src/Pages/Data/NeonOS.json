{
  "portfolioType": "neonOS",
  "templateComponent": "NeonOS",
  "title": "NeonOS — Cinematic Developer Portfolio",
  "sections": [
    {
      "sectionId": "hero",
      "label": "Introduction",
      "instruction": "Your big intro. Name, title, photo, and bio in an OS-styled hero.",
      "fields": [
        {
          "name": "name",
          "label": "Full Name",
          "type": "text",
          "placeholder": "Alex Devlin",
          "required": true
        },
        {
          "name": "title",
          "label": "What You Do",
          "instruction": "Your role or what you specialize in. No job needed.",
          "type": "text",
          "placeholder": "Full Stack Developer",
          "required": true
        },
        {
          "name": "subtitle",
          "label": "Skill Summary",
          "type": "text",
          "placeholder": "Rust · WebAssembly · Distributed Systems",
          "instruction": "A quick line listing your main skills, separated by dots or commas."
        },
        {
          "name": "bio",
          "label": "Short Bio",
          "type": "textarea",
          "placeholder": "I architect systems that scale to millions and ship tools developers actually love. 7 years turning caffeine into reliable infrastructure.",
          "instruction": "2-3 sentences about yourself and what you build.",
          "required": true
        },
        {
          "name": "avatar",
          "label": "Photo",
          "type": "image",
          "multiple": false,
          "instruction": "A clear photo of yourself. Appears inside an animated frame."
        },
        {
          "name": "statusBadge",
          "label": "Status Badge",
          "type": "text",
          "placeholder": "Open to work · Remote",
          "instruction": "A small label near your photo showing your availability."
        },
        {
          "name": "resumeLink",
          "label": "Resume",
          "type": "resume",
          "instruction": "Upload your resume as a PDF (max 5MB)."
        },
        {
          "name": "yearsExp",
          "label": "Years of Experience",
          "type": "text",
          "placeholder": "7",
          "instruction": "Just the number. Shows as a floating stat badge."
        },
        {
          "name": "projectsCount",
          "label": "Projects Shipped",
          "type": "text",
          "placeholder": "40+",
          "instruction": "How many projects you've built. Shows as a stat badge."
        },
        {
          "name": "coffeeCount",
          "label": "Fun Stat",
          "type": "text",
          "placeholder": "∞ coffees",
          "instruction": "A fun or creative stat about yourself."
        }
      ]
    },
    {
      "sectionId": "skills",
      "label": "Skills",
      "instruction": "Group your skills into categories. Each becomes a glowing panel.",
      "type": "array",
      "min": 1,
      "max": 8,
      "item": {
        "fields": [
          {
            "name": "title",
            "label": "Category Name",
            "type": "text",
            "placeholder": "Core Languages",
            "required": true
          },
          {
            "name": "skills",
            "label": "Skills",
            "type": "tags",
            "placeholder": "Rust, Go, TypeScript, Python",
            "instruction": "Type each skill and press Enter to add.",
            "required": true
          }
        ]
      }
    },
    {
      "sectionId": "experience",
      "label": "Work Experience",
      "instruction": "Your job history as an OS log timeline. Turn off if you have none.",
      "fields": [
        {
          "name": "showExperience",
          "label": "Show This Section",
          "type": "boolean",
          "default": true,
          "instruction": "Turn off to hide this section from your portfolio."
        }
      ],
      "type": "array",
      "min": 0,
      "max": 10,
      "item": {
        "fields": [
          {
            "name": "role",
            "label": "Job Title",
            "type": "text",
            "placeholder": "Principal Engineer",
            "required": true
          },
          {
            "name": "company",
            "label": "Company",
            "type": "text",
            "placeholder": "Vercel",
            "required": true
          },
          {
            "name": "period",
            "label": "Duration",
            "type": "text",
            "placeholder": "2022 – Present"
          },
          {
            "name": "location",
            "label": "Location",
            "type": "text",
            "placeholder": "Remote"
          },
          {
            "name": "description",
            "label": "Description",
            "type": "textarea",
            "placeholder": "Owned the edge runtime infrastructure powering 3M+ deployments/day. Reduced cold start latency by 70%.",
            "instruction": "Key responsibilities and achievements. Use numbers where possible."
          }
        ]
      }
    },
    {
      "sectionId": "projects",
      "label": "Projects",
      "instruction": "Your main work showcase. Each gets an interactive OS window card.",
      "type": "array",
      "min": 1,
      "max": 12,
      "item": {
        "fields": [
          {
            "name": "title",
            "label": "Project Name",
            "type": "text",
            "placeholder": "NeuralCache",
            "required": true
          },
          {
            "name": "date",
            "label": "Year",
            "type": "text",
            "placeholder": "2024"
          },
          {
            "name": "description",
            "label": "Description",
            "type": "textarea",
            "placeholder": "An adaptive caching layer using ML to predict cache eviction patterns, achieving 94% hit rate.",
            "instruction": "What it does and what makes it interesting. 2-3 sentences.",
            "required": true
          },
          {
            "name": "image",
            "label": "Screenshot",
            "type": "image",
            "multiple": false,
            "instruction": "Wide (landscape) images look best."
          },
          {
            "name": "tags",
            "label": "Technologies",
            "type": "tags",
            "placeholder": "Rust, Redis, PyTorch, Kubernetes",
            "instruction": "Type each technology and press Enter to add."
          },
          {
            "name": "github",
            "label": "GitHub URL",
            "type": "link",
            "placeholder": "https://github.com/you/neuralcache"
          },
          {
            "name": "webapp",
            "label": "Live URL",
            "type": "link",
            "placeholder": "https://neuralcache.dev"
          },
          {
            "name": "showMembers",
            "label": "Team Project",
            "type": "boolean",
            "default": false,
            "instruction": "Turn on to add team members."
          },
          {
            "name": "member",
            "label": "Team Members",
            "type": "array",
            "min": 0,
            "max": 6,
            "item": {
              "fields": [
                {
                  "name": "name",
                  "label": "Name",
                  "type": "text",
                  "placeholder": "Sara Chen"
                },
                {
                  "name": "github",
                  "label": "GitHub URL",
                  "type": "link",
                  "placeholder": "https://github.com/sarachen"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "sectionId": "education",
      "label": "Education",
      "instruction": "Your academic background. Online courses count too.",
      "type": "array",
      "min": 0,
      "max": 6,
      "item": {
        "fields": [
          {
            "name": "degree",
            "label": "Degree",
            "type": "text",
            "placeholder": "M.Sc. Computer Science",
            "required": true
          },
          {
            "name": "institution",
            "label": "Institution",
            "type": "text",
            "placeholder": "Carnegie Mellon University",
            "required": true
          },
          {
            "name": "period",
            "label": "Years",
            "type": "text",
            "placeholder": "2015 – 2019"
          },
          {
            "name": "grade",
            "label": "Grade / GPA",
            "type": "text",
            "placeholder": "4.0 / 4.0"
          },
          {
            "name": "description",
            "label": "Highlights",
            "type": "textarea",
            "placeholder": "Specialization in distributed systems. Thesis: Self-healing microservice meshes."
          }
        ]
      }
    },
    {
      "sectionId": "certifications",
      "label": "Certifications",
      "instruction": "Professional certificates. Turn off if you have none.",
      "fields": [
        {
          "name": "showCertifications",
          "label": "Show This Section",
          "type": "boolean",
          "default": true,
          "instruction": "Turn off to hide this section from your portfolio."
        }
      ],
      "type": "array",
      "min": 0,
      "max": 12,
      "item": {
        "fields": [
          {
            "name": "name",
            "label": "Certificate Name",
            "type": "text",
            "placeholder": "Certified Kubernetes Administrator (CKA)",
            "required": true
          },
          {
            "name": "issuer",
            "label": "Issued By",
            "type": "text",
            "placeholder": "Cloud Native Computing Foundation"
          },
          {
            "name": "date",
            "label": "Date Completed",
            "type": "text",
            "placeholder": "Nov 2023"
          },
          {
            "name": "link",
            "label": "Verification Link",
            "type": "link",
            "placeholder": "https://credly.com/badges/..."
          }
        ]
      }
    },
    {
      "sectionId": "contact",
      "label": "Contact",
      "instruction": "How people can reach you. Only add platforms you actively use.",
      "fields": [
        {
          "name": "email",
          "label": "Email Address",
          "type": "email",
          "placeholder": "alex@example.com",
          "required": true
        },
        {
          "name": "github",
          "label": "GitHub URL",
          "type": "link",
          "placeholder": "https://github.com/alexdev"
        },
        {
          "name": "linkedin",
          "label": "LinkedIn URL",
          "type": "link",
          "placeholder": "https://linkedin.com/in/alexdev"
        },
        {
          "name": "twitter",
          "label": "Twitter / X URL",
          "type": "link",
          "placeholder": "https://twitter.com/alexdev"
        },
        {
          "name": "facebook",
          "label": "Facebook URL",
          "type": "link",
          "placeholder": "https://facebook.com/alexdev"
        },
        {
          "name": "instagram",
          "label": "Instagram URL",
          "type": "link",
          "placeholder": "https://instagram.com/alexdev"
        },
        {
          "name": "location",
          "label": "Location",
          "type": "text",
          "placeholder": "Berlin, Germany"
        },
        {
          "name": "availability",
          "label": "Availability Note",
          "type": "text",
          "placeholder": "Available for freelance & full-time roles from Jan 2025",
          "instruction": "A short line that appears above your contact info."
        }
      ]
    }
  ]
}
