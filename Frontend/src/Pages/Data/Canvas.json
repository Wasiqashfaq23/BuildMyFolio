{
  "portfolioType": "canvas",
  "templateComponent": "Canvas",
  "title": "Canvas — Clean Minimal Portfolio",
  "sections": [
    {
      "sectionId": "hero",
      "label": "Introduction",
      "instruction": "The first thing visitors see. Make it clear and confident.",
      "fields": [
        {
          "name": "name",
          "label": "Full Name",
          "type": "text",
          "placeholder": "Nour Al-Rashid",
          "required": true
        },
        {
          "name": "title",
          "label": "What You Do",
          "instruction": "Your role or what you specialize in. No job needed.",
          "type": "text",
          "placeholder": "Frontend Developer",
          "required": true
        },
        {
          "name": "tagline",
          "label": "Tagline",
          "type": "text",
          "placeholder": "Turning complex problems into simple, beautiful software.",
          "instruction": "One sentence that sums up what you do."
        },
        {
          "name": "bio",
          "label": "Short Bio",
          "type": "textarea",
          "placeholder": "5 years building products at the intersection of design and engineering. Previously at Notion and Linear.",
          "instruction": "2-3 sentences about yourself and your experience.",
          "required": true
        },
        {
          "name": "avatar",
          "label": "Profile Photo",
          "type": "image",
          "multiple": false,
          "instruction": "A clear headshot with a simple background works best."
        },
        {
          "name": "location",
          "label": "Location",
          "type": "text",
          "placeholder": "Dubai, UAE"
        },
        {
          "name": "availableForWork",
          "label": "Available for Work",
          "type": "boolean",
          "default": true,
          "instruction": "Shows an availability badge on your profile."
        },
        {
          "name": "resumeLink",
          "label": "Resume",
          "type": "resume",
          "instruction": "Upload your resume as a PDF (max 5MB)."
        },
        {
          "name": "ctaLabel",
          "label": "CTA Button Text",
          "type": "text",
          "placeholder": "Available for Work",
          "instruction": "Short action text for the top button, e.g. 'Hire Me' or 'Let's Talk'."
        }
      ]
    },
    {
      "sectionId": "skills",
      "label": "Skills",
      "instruction": "Group your skills into categories.",
      "type": "array",
      "min": 1,
      "max": 6,
      "item": {
        "fields": [
          {
            "name": "title",
            "label": "Category Name",
            "type": "text",
            "placeholder": "Frontend Development",
            "required": true
          },
          {
            "name": "skills",
            "label": "Skills",
            "type": "tags",
            "placeholder": "React, TypeScript, Next.js",
            "instruction": "Type each skill and press Enter to add.",
            "required": true
          }
        ]
      }
    },
    {
      "sectionId": "experience",
      "label": "Work Experience",
      "instruction": "Add jobs, internships, or freelance work. Turn off if you have none.",
      "fields": [
        {
          "name": "showExperience",
          "label": "Show This Section",
          "type": "boolean",
          "default": true,
          "instruction": "Turn off to hide this section from your portfolio."
        }
      ],
      "type": "array",
      "min": 0,
      "max": 8,
      "item": {
        "fields": [
          {
            "name": "role",
            "label": "Job Title",
            "type": "text",
            "placeholder": "Senior Product Designer",
            "required": true
          },
          {
            "name": "company",
            "label": "Company",
            "type": "text",
            "placeholder": "Notion",
            "required": true
          },
          {
            "name": "period",
            "label": "Duration",
            "type": "text",
            "placeholder": "Mar 2022 – Present"
          },
          {
            "name": "location",
            "label": "Location",
            "type": "text",
            "placeholder": "Remote"
          },
          {
            "name": "description",
            "label": "Description",
            "type": "textarea",
            "placeholder": "Led design for the mobile app used by 4M+ users. Reduced onboarding drop-off by 32%.",
            "instruction": "Key responsibilities and achievements. Use numbers where possible."
          }
        ]
      }
    },
    {
      "sectionId": "projects",
      "label": "Projects",
      "instruction": "Your best work. This is what employers look at first.",
      "type": "array",
      "min": 1,
      "max": 8,
      "item": {
        "fields": [
          {
            "name": "title",
            "label": "Project Name",
            "type": "text",
            "placeholder": "Taskflow — Project Management App",
            "required": true
          },
          {
            "name": "date",
            "label": "Year",
            "type": "text",
            "placeholder": "2024"
          },
          {
            "name": "description",
            "label": "Description",
            "type": "textarea",
            "placeholder": "A lightweight project management tool for solo developers. Used by 800+ people since launch.",
            "instruction": "What it does, who uses it, and any impressive numbers.",
            "required": true
          },
          {
            "name": "image",
            "label": "Screenshot",
            "type": "image",
            "multiple": false,
            "instruction": "The most visually appealing view of your project."
          },
          {
            "name": "tags",
            "label": "Technologies",
            "type": "tags",
            "placeholder": "Next.js, Supabase, Tailwind",
            "instruction": "Type each technology and press Enter to add."
          },
          {
            "name": "github",
            "label": "GitHub URL",
            "type": "link",
            "placeholder": "https://github.com/you/taskflow"
          },
          {
            "name": "webapp",
            "label": "Live URL",
            "type": "link",
            "placeholder": "https://taskflow.app"
          },
          {
            "name": "showMembers",
            "label": "Team Project",
            "type": "boolean",
            "default": false,
            "instruction": "Turn on to add team members."
          },
          {
            "name": "member",
            "label": "Team Members",
            "type": "array",
            "min": 0,
            "max": 5,
            "item": {
              "fields": [
                {
                  "name": "name",
                  "label": "Name",
                  "type": "text",
                  "placeholder": "Omar Faruk"
                },
                {
                  "name": "github",
                  "label": "GitHub URL",
                  "type": "link",
                  "placeholder": "https://github.com/omarfaruk"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "sectionId": "education",
      "label": "Education",
      "instruction": "Your academic background. Include ongoing studies too.",
      "type": "array",
      "min": 0,
      "max": 4,
      "item": {
        "fields": [
          {
            "name": "degree",
            "label": "Degree",
            "type": "text",
            "placeholder": "B.Sc. Computer Science",
            "required": true
          },
          {
            "name": "institution",
            "label": "Institution",
            "type": "text",
            "placeholder": "American University of Beirut",
            "required": true
          },
          {
            "name": "period",
            "label": "Years",
            "type": "text",
            "placeholder": "2018 – 2022"
          },
          {
            "name": "grade",
            "label": "Grade / GPA",
            "type": "text",
            "placeholder": "3.9 / 4.0"
          },
          {
            "name": "description",
            "label": "Highlights",
            "type": "textarea",
            "placeholder": "Thesis on distributed caching systems. Dean's List for three consecutive years."
          }
        ]
      }
    },
    {
      "sectionId": "certifications",
      "label": "Certifications",
      "instruction": "Online courses or professional certificates. Turn off if you have none.",
      "fields": [
        {
          "name": "showCertifications",
          "label": "Show This Section",
          "type": "boolean",
          "default": true,
          "instruction": "Turn off to hide this section from your portfolio."
        }
      ],
      "type": "array",
      "min": 0,
      "max": 8,
      "item": {
        "fields": [
          {
            "name": "name",
            "label": "Certificate Name",
            "type": "text",
            "placeholder": "AWS Certified Developer – Associate",
            "required": true
          },
          {
            "name": "issuer",
            "label": "Issued By",
            "type": "text",
            "placeholder": "Amazon Web Services"
          },
          {
            "name": "date",
            "label": "Date Completed",
            "type": "text",
            "placeholder": "June 2023"
          },
          {
            "name": "link",
            "label": "Verification Link",
            "type": "link",
            "placeholder": "https://credly.com/badges/abc123"
          }
        ]
      }
    },
    {
      "sectionId": "contact",
      "label": "Contact",
      "instruction": "How people can reach you.",
      "fields": [
        {
          "name": "email",
          "label": "Email Address",
          "type": "email",
          "placeholder": "nour@example.com",
          "required": true
        },
        {
          "name": "github",
          "label": "GitHub URL",
          "type": "link",
          "placeholder": "https://github.com/nouralrashid"
        },
        {
          "name": "linkedin",
          "label": "LinkedIn URL",
          "type": "link",
          "placeholder": "https://linkedin.com/in/nouralrashid"
        },
        {
          "name": "twitter",
          "label": "Twitter / X URL",
          "type": "link",
          "placeholder": "https://twitter.com/nouralrashid"
        },
        {
          "name": "facebook",
          "label": "Facebook URL",
          "type": "link",
          "placeholder": "https://facebook.com/nouralrashid"
        },
        {
          "name": "instagram",
          "label": "Instagram URL",
          "type": "link",
          "placeholder": "https://instagram.com/nouralrashid"
        }
      ]
    }
  ]
}
