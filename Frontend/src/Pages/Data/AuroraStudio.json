{
  "portfolioType": "auroraStudio",
  "templateComponent": "AuroraStudio",
  "title": "Aurora Studio — Modern Motion Portfolio",
  "sections": [
    {
      "sectionId": "hero",
      "label": "Introduction",
      "instruction": "Your big intro with name, title, photo, and bio.",
      "fields": [
        {
          "name": "ctaLabel",
          "label": "CTA Button Text",
          "type": "text",
          "placeholder": "Hire Me",
          "instruction": "Short action text for the top button, e.g. 'Hire Me' or 'Let's Talk'."
        },
        {
          "name": "name",
          "label": "Full Name",
          "type": "text",
          "placeholder": "Ali Hassan",
          "required": true
        },
        {
          "name": "title",
          "label": "What You Do",
          "instruction": "Your role or what you specialize in. No job needed.",
          "type": "text",
          "placeholder": "Full Stack Developer",
          "required": true
        },
        {
          "name": "subtitle",
          "label": "Skill Summary",
          "type": "text",
          "placeholder": "React · Node.js · MongoDB",
          "instruction": "A quick line listing your main skills, separated by dots or commas."
        },
        {
          "name": "bio",
          "label": "Short Bio",
          "type": "textarea",
          "placeholder": "I build fast, clean web apps from frontend to backend. I specialize in React and Node.js with a focus on real-world projects.",
          "instruction": "2-3 sentences about yourself and what you build.",
          "required": true
        },
        {
          "name": "avatar",
          "label": "Photo",
          "type": "image",
          "multiple": false,
          "instruction": "A clear photo of yourself. Appears in an animated circular frame."
        },
        {
          "name": "badge1",
          "label": "Badge 1",
          "type": "text",
          "placeholder": "3+ Years Exp",
          "instruction": "A floating label near your photo with a quick fact."
        },
        {
          "name": "badge2",
          "label": "Badge 2",
          "type": "text",
          "placeholder": "10+ Projects"
        },
        {
          "name": "badge3",
          "label": "Badge 3",
          "type": "text",
          "placeholder": "5 Happy Clients"
        },
        {
          "name": "resumeLink",
          "label": "Resume",
          "type": "resume",
          "instruction": "Upload your resume as a PDF (max 5MB)."
        },
        {
          "name": "showreel",
          "label": "Work Video Link",
          "type": "link",
          "placeholder": "https://youtu.be/your-video",
          "instruction": "A YouTube or Vimeo video showcasing your work."
        }
      ]
    },
    {
      "sectionId": "skills",
      "label": "Skills",
      "instruction": "Group your skills into categories. Each becomes an animated card.",
      "type": "array",
      "min": 1,
      "max": 8,
      "item": {
        "fields": [
          {
            "name": "title",
            "label": "Category Name",
            "type": "text",
            "placeholder": "Frontend",
            "required": true
          },
          {
            "name": "skills",
            "label": "Skills",
            "type": "tags",
            "placeholder": "React, JavaScript, Tailwind CSS",
            "instruction": "Type each skill and press Enter to add.",
            "required": true
          }
        ]
      }
    },
    {
      "sectionId": "experience",
      "label": "Work Experience",
      "instruction": "Your job history as timeline cards. Turn off if you have none.",
      "fields": [
        {
          "name": "showExperience",
          "label": "Show This Section",
          "type": "boolean",
          "default": true,
          "instruction": "Turn off to hide this section from your portfolio."
        }
      ],
      "type": "array",
      "min": 0,
      "max": 10,
      "item": {
        "fields": [
          {
            "name": "role",
            "label": "Job Title",
            "type": "text",
            "placeholder": "Freelance Web Developer",
            "required": true
          },
          {
            "name": "company",
            "label": "Company",
            "type": "text",
            "placeholder": "Self-employed",
            "required": true
          },
          {
            "name": "period",
            "label": "Duration",
            "type": "text",
            "placeholder": "Jan 2023 – Present"
          },
          {
            "name": "location",
            "label": "Location",
            "type": "text",
            "placeholder": "Remote"
          },
          {
            "name": "description",
            "label": "Description",
            "type": "textarea",
            "placeholder": "Built and maintained client websites using React and Node.js. Delivered 3 projects on time.",
            "instruction": "Key responsibilities and achievements. Use numbers where possible."
          }
        ]
      }
    },
    {
      "sectionId": "projects",
      "label": "Projects",
      "instruction": "Your main work showcase. Best work goes first.",
      "type": "array",
      "min": 1,
      "max": 12,
      "item": {
        "fields": [
          {
            "name": "title",
            "label": "Project Name",
            "type": "text",
            "placeholder": "Portfolio Maker App",
            "required": true
          },
          {
            "name": "date",
            "label": "Year",
            "type": "text",
            "placeholder": "2024"
          },
          {
            "name": "description",
            "label": "Description",
            "type": "textarea",
            "placeholder": "A web app where users pick a template, fill in their info, and get a hosted portfolio page.",
            "instruction": "What it does and what makes it interesting. 2-3 sentences.",
            "required": true
          },
          {
            "name": "image",
            "label": "Screenshot",
            "type": "image",
            "multiple": false,
            "instruction": "Wide (landscape) images look best."
          },
          {
            "name": "tags",
            "label": "Technologies",
            "type": "tags",
            "placeholder": "React, Node.js, MongoDB, Express",
            "instruction": "Type each technology and press Enter to add."
          },
          {
            "name": "github",
            "label": "GitHub URL",
            "type": "link",
            "placeholder": "https://github.com/yourname/project"
          },
          {
            "name": "webapp",
            "label": "Live URL",
            "type": "link",
            "placeholder": "https://your-project.vercel.app"
          },
          {
            "name": "showMembers",
            "label": "Team Project",
            "type": "boolean",
            "default": false,
            "instruction": "Turn on to add team members."
          },
          {
            "name": "member",
            "label": "Team Members",
            "type": "array",
            "min": 0,
            "max": 6,
            "item": {
              "fields": [
                {
                  "name": "name",
                  "label": "Name",
                  "type": "text",
                  "placeholder": "Bilal Ahmed"
                },
                {
                  "name": "github",
                  "label": "GitHub URL",
                  "type": "link",
                  "placeholder": "https://github.com/bilalahmed"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "sectionId": "education",
      "label": "Education",
      "instruction": "Your academic background. Online courses count too.",
      "type": "array",
      "min": 0,
      "max": 6,
      "item": {
        "fields": [
          {
            "name": "degree",
            "label": "Degree",
            "type": "text",
            "placeholder": "BS Computer Science",
            "required": true
          },
          {
            "name": "institution",
            "label": "Institution",
            "type": "text",
            "placeholder": "University of the Punjab",
            "required": true
          },
          {
            "name": "period",
            "label": "Years",
            "type": "text",
            "placeholder": "2020 – 2024"
          },
          {
            "name": "grade",
            "label": "Grade / GPA",
            "type": "text",
            "placeholder": "3.5 GPA"
          },
          {
            "name": "description",
            "label": "Highlights",
            "type": "textarea",
            "placeholder": "Specialized in web technologies. Final year project: an AI-powered chatbot."
          }
        ]
      }
    },
    {
      "sectionId": "certifications",
      "label": "Certifications",
      "instruction": "Professional certificates. Turn off if you have none.",
      "fields": [
        {
          "name": "showCertifications",
          "label": "Show This Section",
          "type": "boolean",
          "default": true,
          "instruction": "Turn off to hide this section from your portfolio."
        }
      ],
      "type": "array",
      "min": 0,
      "max": 12,
      "item": {
        "fields": [
          {
            "name": "name",
            "label": "Certificate Name",
            "type": "text",
            "placeholder": "The Complete Web Developer Bootcamp",
            "required": true
          },
          {
            "name": "issuer",
            "label": "Issued By",
            "type": "text",
            "placeholder": "Udemy"
          },
          {
            "name": "date",
            "label": "Date Completed",
            "type": "text",
            "placeholder": "March 2024"
          },
          {
            "name": "link",
            "label": "Verification Link",
            "type": "link",
            "placeholder": "https://udemy.com/certificate/your-id"
          }
        ]
      }
    },
    {
      "sectionId": "contact",
      "label": "Contact",
      "instruction": "How people can reach you. Only add platforms you actively use.",
      "fields": [
        {
          "name": "email",
          "label": "Email Address",
          "type": "email",
          "placeholder": "ali@gmail.com",
          "required": true
        },
        {
          "name": "github",
          "label": "GitHub URL",
          "type": "link",
          "placeholder": "https://github.com/yourname"
        },
        {
          "name": "linkedin",
          "label": "LinkedIn URL",
          "type": "link",
          "placeholder": "https://linkedin.com/in/yourname"
        },
        {
          "name": "twitter",
          "label": "Twitter / X URL",
          "type": "link",
          "placeholder": "https://twitter.com/yourname"
        },
        {
          "name": "facebook",
          "label": "Facebook URL",
          "type": "link",
          "placeholder": "https://facebook.com/yourname"
        },
        {
          "name": "instagram",
          "label": "Instagram URL",
          "type": "link",
          "placeholder": "https://instagram.com/yourname"
        },
        {
          "name": "location",
          "label": "Location",
          "type": "text",
          "placeholder": "Faisalabad, Pakistan"
        },
        {
          "name": "tagline",
          "label": "Contact Tagline",
          "type": "text",
          "placeholder": "Got a project in mind? Let's talk.",
          "instruction": "A short friendly line above your contact info."
        }
      ]
    }
  ]
}
