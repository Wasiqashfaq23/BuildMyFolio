PORT=8001
NODE_ENV=development

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/buildmyfolio?retryWrites=true&w=majority

# Secret used to sign and verify JWTs — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this

# Your frontend URL (used for CORS)
FRONTEND_URI=http://localhost:5173

# Cloudinary — get these from cloudinary.com > Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google OAuth client ID — from console.cloud.google.com > APIs & Services > Credentials
OAUTH_CLIENT_ID=123456789-abcdefghijklmnop.apps.googleusercontent.com
