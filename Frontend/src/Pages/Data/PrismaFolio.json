{
  "portfolioType": "PrismaFolio",
  "templateComponent": "PrismaFolio",
  "title": "Prisma — Bold Editorial Portfolio",
  "sections": [
    {
      "sectionId": "hero",
      "label": "Introduction",
      "instruction": "Bold editorial intro. Your name dominates the screen.",
      "fields": [
        {
          "name": "ctaLabel",
          "label": "CTA Button Text",
          "type": "text",
          "placeholder": "Work Together",
          "instruction": "Short action text for the top button, e.g. 'Hire Me' or 'Work Together'."
        },
        {
          "name": "name",
          "label": "Full Name",
          "type": "text",
          "placeholder": "Kai Oduya",
          "required": true
        },
        {
          "name": "role",
          "label": "What You Do",
          "instruction": "Your role or what you specialize in. No job needed.",
          "type": "text",
          "placeholder": "MERN Stack Developer",
          "required": true
        },
        {
          "name": "descriptor",
          "label": "Tagline",
          "type": "text",
          "placeholder": "Crafting digital products people actually love.",
          "instruction": "One punchy sentence that sums up your approach."
        },
        {
          "name": "bio",
          "label": "Short Bio",
          "type": "textarea",
          "placeholder": "6 years turning complex problems into elegant solutions. I care deeply about performance, accessibility, and the tiny details.",
          "instruction": "2-3 sentences about yourself and what you build.",
          "required": true
        },
        {
          "name": "avatar",
          "label": "Photo",
          "type": "image",
          "multiple": false,
          "instruction": "A clear photo of yourself for the hero section."
        },
        {
          "name": "tag1",
          "label": "Expertise Tag 1",
          "type": "text",
          "placeholder": "React",
          "instruction": "A keyword for your top skill. Shows as a highlighted tag."
        },
        {
          "name": "tag2",
          "label": "Expertise Tag 2",
          "type": "text",
          "placeholder": "Node.js"
        },
        {
          "name": "tag3",
          "label": "Expertise Tag 3",
          "type": "text",
          "placeholder": "System Design"
        },
        {
          "name": "stat1Label",
          "label": "Stat 1 Label",
          "type": "text",
          "placeholder": "Years Building"
        },
        {
          "name": "stat1Value",
          "label": "Stat 1 Value",
          "type": "text",
          "placeholder": "6"
        },
        {
          "name": "stat2Label",
          "label": "Stat 2 Label",
          "type": "text",
          "placeholder": "Projects Shipped"
        },
        {
          "name": "stat2Value",
          "label": "Stat 2 Value",
          "type": "text",
          "placeholder": "50+"
        },
        {
          "name": "stat3Label",
          "label": "Stat 3 Label",
          "type": "text",
          "placeholder": "Happy Clients"
        },
        {
          "name": "stat3Value",
          "label": "Stat 3 Value",
          "type": "text",
          "placeholder": "20+"
        },
        {
          "name": "resumeLink",
          "label": "Resume",
          "type": "resume",
          "instruction": "Upload your resume as a PDF (max 5MB)."
        }
      ]
    },
    {
      "sectionId": "skills",
      "label": "Skills",
      "instruction": "Group your skills into categories.",
      "type": "array",
      "min": 1,
      "max": 8,
      "item": {
        "fields": [
          {
            "name": "title",
            "label": "Category Name",
            "type": "text",
            "placeholder": "Frontend",
            "required": true
          },
          {
            "name": "skills",
            "label": "Skills",
            "type": "tags",
            "placeholder": "React, TypeScript, Next.js, Framer Motion",
            "instruction": "Type each skill and press Enter to add.",
            "required": true
          }
        ]
      }
    },
    {
      "sectionId": "experience",
      "label": "Work Experience",
      "instruction": "Your job history as a numbered timeline. Turn off if you have none.",
      "fields": [
        {
          "name": "showExperience",
          "label": "Show This Section",
          "type": "boolean",
          "default": true,
          "instruction": "Turn off to hide this section from your portfolio."
        }
      ],
      "type": "array",
      "min": 0,
      "max": 10,
      "item": {
        "fields": [
          {
            "name": "role",
            "label": "Job Title",
            "type": "text",
            "placeholder": "Senior Engineer",
            "required": true
          },
          {
            "name": "company",
            "label": "Company",
            "type": "text",
            "placeholder": "Linear",
            "required": true
          },
          {
            "name": "period",
            "label": "Duration",
            "type": "text",
            "placeholder": "2021 – Present"
          },
          {
            "name": "location",
            "label": "Location",
            "type": "text",
            "placeholder": "Remote"
          },
          {
            "name": "description",
            "label": "Description",
            "type": "textarea",
            "placeholder": "Rebuilt the core rendering pipeline, cutting frame drop rate by 80% on low-end devices.",
            "instruction": "Key responsibilities and achievements. Use numbers where possible."
          }
        ]
      }
    },
    {
      "sectionId": "projects",
      "label": "Projects",
      "instruction": "Your main work showcase. Best work goes first.",
      "type": "array",
      "min": 1,
      "max": 12,
      "item": {
        "fields": [
          {
            "name": "title",
            "label": "Project Name",
            "type": "text",
            "placeholder": "Volta — Real-Time Analytics",
            "required": true
          },
          {
            "name": "date",
            "label": "Year",
            "type": "text",
            "placeholder": "2024"
          },
          {
            "name": "description",
            "label": "Description",
            "type": "textarea",
            "placeholder": "Event-driven analytics engine processing 1M+ events/day with sub-100ms query times.",
            "instruction": "What it does and what makes it interesting. 2-3 sentences.",
            "required": true
          },
          {
            "name": "image",
            "label": "Screenshot",
            "type": "image",
            "multiple": false,
            "instruction": "Wide (landscape) images look best."
          },
          {
            "name": "tags",
            "label": "Technologies",
            "type": "tags",
            "placeholder": "TypeScript, ClickHouse, Kafka, React",
            "instruction": "Type each technology and press Enter to add."
          },
          {
            "name": "github",
            "label": "GitHub URL",
            "type": "link",
            "placeholder": "https://github.com/you/volta"
          },
          {
            "name": "webapp",
            "label": "Live URL",
            "type": "link",
            "placeholder": "https://volta.dev"
          },
          {
            "name": "showMembers",
            "label": "Team Project",
            "type": "boolean",
            "default": false,
            "instruction": "Turn on to add team members."
          },
          {
            "name": "member",
            "label": "Team Members",
            "type": "array",
            "min": 0,
            "max": 6,
            "item": {
              "fields": [
                {
                  "name": "name",
                  "label": "Name",
                  "type": "text",
                  "placeholder": "Sam Reyes"
                },
                {
                  "name": "github",
                  "label": "GitHub URL",
                  "type": "link",
                  "placeholder": "https://github.com/samreyes"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "sectionId": "education",
      "label": "Education",
      "instruction": "Your academic background. Online courses count too.",
      "type": "array",
      "min": 0,
      "max": 6,
      "item": {
        "fields": [
          {
            "name": "degree",
            "label": "Degree",
            "type": "text",
            "placeholder": "B.Sc. Computer Science",
            "required": true
          },
          {
            "name": "institution",
            "label": "Institution",
            "type": "text",
            "placeholder": "University of Cape Town",
            "required": true
          },
          {
            "name": "period",
            "label": "Years",
            "type": "text",
            "placeholder": "2014 – 2018"
          },
          {
            "name": "grade",
            "label": "Grade / GPA",
            "type": "text",
            "placeholder": "First Class Honours"
          },
          {
            "name": "description",
            "label": "Highlights",
            "type": "textarea",
            "placeholder": "Thesis: Optimising graph traversal algorithms for social network analysis."
          }
        ]
      }
    },
    {
      "sectionId": "certifications",
      "label": "Certifications",
      "instruction": "Professional certificates. Turn off if you have none.",
      "fields": [
        {
          "name": "showCertifications",
          "label": "Show This Section",
          "type": "boolean",
          "default": true,
          "instruction": "Turn off to hide this section from your portfolio."
        }
      ],
      "type": "array",
      "min": 0,
      "max": 12,
      "item": {
        "fields": [
          {
            "name": "name",
            "label": "Certificate Name",
            "type": "text",
            "placeholder": "AWS Solutions Architect — Professional",
            "required": true
          },
          {
            "name": "issuer",
            "label": "Issued By",
            "type": "text",
            "placeholder": "Amazon Web Services"
          },
          {
            "name": "date",
            "label": "Date Completed",
            "type": "text",
            "placeholder": "Aug 2023"
          },
          {
            "name": "link",
            "label": "Verification Link",
            "type": "link",
            "placeholder": "https://credly.com/badges/..."
          }
        ]
      }
    },
    {
      "sectionId": "contact",
      "label": "Contact",
      "instruction": "How people can reach you. Only add platforms you actively use.",
      "fields": [
        {
          "name": "email",
          "label": "Email Address",
          "type": "email",
          "placeholder": "kai@studio.com",
          "required": true
        },
        {
          "name": "github",
          "label": "GitHub URL",
          "type": "link",
          "placeholder": "https://github.com/kaioduya"
        },
        {
          "name": "linkedin",
          "label": "LinkedIn URL",
          "type": "link",
          "placeholder": "https://linkedin.com/in/kaioduya"
        },
        {
          "name": "twitter",
          "label": "Twitter / X URL",
          "type": "link",
          "placeholder": "https://twitter.com/kaioduya"
        },
        {
          "name": "facebook",
          "label": "Facebook URL",
          "type": "link",
          "placeholder": "https://facebook.com/kaioduya"
        },
        {
          "name": "instagram",
          "label": "Instagram URL",
          "type": "link",
          "placeholder": "https://instagram.com/kaioduya"
        },
        {
          "name": "location",
          "label": "Location",
          "type": "text",
          "placeholder": "Lagos, Nigeria"
        },
        {
          "name": "ctaHeadline",
          "label": "Contact Tagline",
          "type": "text",
          "placeholder": "Got a project in mind?",
          "instruction": "A short friendly line above your contact info."
        }
      ]
    }
  ]
}
