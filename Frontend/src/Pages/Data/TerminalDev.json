{
  "portfolioType": "terminalDev",
  "templateComponent": "TerminalDev",
  "title": "Terminal Dev — Hacker Portfolio",
  "sections": [
    {
      "sectionId": "hero",
      "label": "Introduction",
      "instruction": "Your intro styled as a terminal boot sequence.",
      "fields": [
        {
          "name": "name",
          "label": "Full Name",
          "type": "text",
          "placeholder": "John Doe",
          "required": true
        },
        {
          "name": "title",
          "label": "What You Do",
          "instruction": "Your role or what you specialize in. No job needed.",
          "type": "text",
          "placeholder": "Full Stack Developer",
          "required": true
        },
        {
          "name": "tagline",
          "label": "Short Bio",
          "type": "textarea",
          "placeholder": "I build things for the web. Open source enthusiast. Coffee-driven engineer.",
          "instruction": "1-3 sentences about yourself. Appears as terminal output.",
          "required": true
        },
        {
          "name": "avatar",
          "label": "Photo",
          "type": "image",
          "multiple": false,
          "instruction": "A clear photo of yourself. Appears in an ASCII-bordered frame."
        },
        {
          "name": "resumeLink",
          "label": "Resume",
          "type": "resume",
          "instruction": "Upload your resume as a PDF (max 5MB)."
        }
      ]
    },
    {
      "sectionId": "skills",
      "label": "Skills",
      "instruction": "Group your skills into categories. Each becomes a terminal list block.",
      "type": "array",
      "min": 1,
      "max": 8,
      "item": {
        "fields": [
          {
            "name": "title",
            "label": "Category Name",
            "type": "text",
            "placeholder": "Languages",
            "required": true
          },
          {
            "name": "skills",
            "label": "Skills",
            "type": "tags",
            "placeholder": "JavaScript, TypeScript, Python",
            "instruction": "Type each skill and press Enter to add.",
            "required": true
          }
        ]
      }
    },
    {
      "sectionId": "experience",
      "label": "Work Experience",
      "instruction": "Your job history as terminal log entries. Turn off if you have none.",
      "fields": [
        {
          "name": "showExperience",
          "label": "Show This Section",
          "type": "boolean",
          "default": true,
          "instruction": "Turn off to hide this section from your portfolio."
        }
      ],
      "type": "array",
      "min": 0,
      "max": 10,
      "item": {
        "fields": [
          {
            "name": "role",
            "label": "Job Title",
            "type": "text",
            "placeholder": "Senior Frontend Engineer",
            "required": true
          },
          {
            "name": "company",
            "label": "Company",
            "type": "text",
            "placeholder": "Acme Corp",
            "required": true
          },
          {
            "name": "period",
            "label": "Duration",
            "type": "text",
            "placeholder": "Jan 2021 – Present"
          },
          {
            "name": "location",
            "label": "Location",
            "type": "text",
            "placeholder": "Remote"
          },
          {
            "name": "description",
            "label": "Description",
            "type": "textarea",
            "placeholder": "Led the rebuild of the main dashboard, reducing load time by 60%...",
            "instruction": "Key responsibilities and achievements. Use numbers where possible."
          }
        ]
      }
    },
    {
      "sectionId": "projects",
      "label": "Projects",
      "instruction": "Your main work showcase. Best work goes first.",
      "type": "array",
      "min": 1,
      "max": 12,
      "item": {
        "fields": [
          {
            "name": "title",
            "label": "Project Name",
            "type": "text",
            "placeholder": "QuantumDB",
            "required": true
          },
          {
            "name": "date",
            "label": "Year",
            "type": "text",
            "placeholder": "2024"
          },
          {
            "name": "description",
            "label": "Description",
            "type": "textarea",
            "placeholder": "A blazing-fast distributed database engine written in Rust.",
            "instruction": "What it does and what makes it interesting. 2-3 sentences.",
            "required": true
          },
          {
            "name": "image",
            "label": "Screenshot",
            "type": "image",
            "multiple": false,
            "instruction": "Wide (landscape) images look best."
          },
          {
            "name": "tags",
            "label": "Technologies",
            "type": "tags",
            "placeholder": "Rust, PostgreSQL, Docker",
            "instruction": "Type each technology and press Enter to add."
          },
          {
            "name": "github",
            "label": "GitHub URL",
            "type": "link",
            "placeholder": "https://github.com/you/quantumdb"
          },
          {
            "name": "webapp",
            "label": "Live URL",
            "type": "link",
            "placeholder": "https://quantumdb.dev"
          },
          {
            "name": "showMembers",
            "label": "Team Project",
            "type": "boolean",
            "default": false,
            "instruction": "Turn on to add team members."
          },
          {
            "name": "member",
            "label": "Team Members",
            "type": "array",
            "min": 0,
            "max": 6,
            "item": {
              "fields": [
                {
                  "name": "name",
                  "label": "Name",
                  "type": "text",
                  "placeholder": "Jane Smith"
                },
                {
                  "name": "github",
                  "label": "GitHub URL",
                  "type": "link",
                  "placeholder": "https://github.com/janesmith"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "sectionId": "education",
      "label": "Education",
      "instruction": "Your academic background. Online courses count too.",
      "type": "array",
      "min": 0,
      "max": 6,
      "item": {
        "fields": [
          {
            "name": "degree",
            "label": "Degree",
            "type": "text",
            "placeholder": "B.Sc. Computer Science",
            "required": true
          },
          {
            "name": "institution",
            "label": "Institution",
            "type": "text",
            "placeholder": "MIT",
            "required": true
          },
          {
            "name": "period",
            "label": "Years",
            "type": "text",
            "placeholder": "2016 – 2020"
          },
          {
            "name": "grade",
            "label": "Grade / GPA",
            "type": "text",
            "placeholder": "3.9 / 4.0"
          },
          {
            "name": "description",
            "label": "Highlights",
            "type": "textarea",
            "placeholder": "Thesis: Optimizing Neural Network Inference on Edge Devices."
          }
        ]
      }
    },
    {
      "sectionId": "certifications",
      "label": "Certifications",
      "instruction": "Professional certificates. Turn off if you have none.",
      "fields": [
        {
          "name": "showCertifications",
          "label": "Show This Section",
          "type": "boolean",
          "default": true,
          "instruction": "Turn off to hide this section from your portfolio."
        }
      ],
      "type": "array",
      "min": 0,
      "max": 12,
      "item": {
        "fields": [
          {
            "name": "name",
            "label": "Certificate Name",
            "type": "text",
            "placeholder": "AWS Certified Solutions Architect",
            "required": true
          },
          {
            "name": "issuer",
            "label": "Issued By",
            "type": "text",
            "placeholder": "Amazon Web Services"
          },
          {
            "name": "date",
            "label": "Date Completed",
            "type": "text",
            "placeholder": "March 2023"
          },
          {
            "name": "link",
            "label": "Verification Link",
            "type": "link",
            "placeholder": "https://credly.com/badges/..."
          }
        ]
      }
    },
    {
      "sectionId": "contact",
      "label": "Contact",
      "instruction": "How people can reach you. Only add platforms you actively use.",
      "fields": [
        {
          "name": "email",
          "label": "Email Address",
          "type": "email",
          "placeholder": "john@example.com",
          "required": true
        },
        {
          "name": "github",
          "label": "GitHub URL",
          "type": "link",
          "placeholder": "https://github.com/johndoe"
        },
        {
          "name": "linkedin",
          "label": "LinkedIn URL",
          "type": "link",
          "placeholder": "https://linkedin.com/in/johndoe"
        },
        {
          "name": "twitter",
          "label": "Twitter / X URL",
          "type": "link",
          "placeholder": "https://twitter.com/johndoe"
        },
        {
          "name": "facebook",
          "label": "Facebook URL",
          "type": "link",
          "placeholder": "https://facebook.com/johndoe"
        },
        {
          "name": "instagram",
          "label": "Instagram URL",
          "type": "link",
          "placeholder": "https://instagram.com/johndoe"
        },
        {
          "name": "location",
          "label": "Location",
          "type": "text",
          "placeholder": "San Francisco, CA"
        }
      ]
    }
  ]
}
